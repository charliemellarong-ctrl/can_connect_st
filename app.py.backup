# Add project root to path
sys.path.insert(0, str(Path(__file__).parent))

from utils.auth_utils import (
    is_authenticated,
    get_user_role,
    get_user_info,
    logout_user,
    login_user,
    register_user
)
from utils.document_definitions import get_all_documents, get_all_categories, CATEGORIES

# ===========================
# Page Configuration
